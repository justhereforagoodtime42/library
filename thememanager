	function ThemeManager:GetPaths()
		local paths = {}
		local parts = string.split(self.Folder, "/")
		for idx = 1, #parts do
			paths[#paths + 1] = table.concat(parts, "/", 1, idx)
		end
		paths[#paths + 1] = self.Folder .. "/themes"
		return paths
	end

	function ThemeManager:BuildFolderTree()
		for _, str in self:GetPaths() do
			if not isfolder(str) then
				makefolder(str)
			end
		end
	end

	function ThemeManager:CheckFolderTree()
		if isfolder(self.Folder) then
			return
		end
		self:BuildFolderTree()
		task.wait(0.1)
	end

	function ThemeManager:SetFolder(folder)
		self.Folder = folder
		self:BuildFolderTree()
	end

	function ThemeManager:HexToColor(hex: string): Color3
		local h = hex:gsub("#", ""):gsub("%s", "")
		local ok, c = pcall(Color3.fromHex, h)
		if ok and typeof(c) == "Color3" then
			return c
		end
		return Color3.new(1, 1, 1)
	end

	--[[ Maps Obsidian-style scheme keys onto AcidHub Library.Theme ]]
	function ThemeManager:ApplyScheme(scheme: { [string]: string })
		local T = self.Library.Theme
		if scheme.FontColor then
			T.Text = self:HexToColor(scheme.FontColor)
		end
		if scheme.BackgroundColor then
			T.Background = self:HexToColor(scheme.BackgroundColor)
		end
		if scheme.MainColor then
			local m = self:HexToColor(scheme.MainColor)
			T.Panel = m
			T.Elevated = m:Lerp(Color3.new(1, 1, 1), 0.12)
			T.SliderTrack = m:Lerp(Color3.new(0, 0, 0), 0.35)
		end
		if scheme.AccentColor then
			local a = self:HexToColor(scheme.AccentColor)
			T.AccentBlue = a
			T.AccentPurple = a:Lerp(Color3.fromRGB(255, 120, 255), 0.22)
			T.ToggleOn = a
			T.SectionDot = a:Lerp(Color3.fromRGB(90, 220, 150), 0.4)
		end
		if scheme.OutlineColor then
			T.Stroke = self:HexToColor(scheme.OutlineColor)
		end
		T.TextDim = T.Text:Lerp(T.Background, 0.42)
		T.ToggleOff = T.Panel:Lerp(Color3.new(0, 0, 0), 0.25)

		for _, field in ThemeFields do
			local hex = scheme[field]
			if typeof(hex) == "string" and hex ~= "" then
				local opt = self.Library.Options[field]
				if opt and opt.SetValueRGB then
					opt:SetValueRGB(self:HexToColor(hex), 0)
				end
			end
		end

		self.Library:RefreshTheme()
	end

	function ThemeManager:ApplyTheme(themeName: string)
		local custom = self:GetCustomTheme(themeName)
		local built = self.BuiltInThemes[themeName]
		local flat: { [string]: string }? = nil
		if custom and type(custom) == "table" then
			flat = custom
		elseif built and type(built[2]) == "table" then
			flat = built[2]
		end
		if flat then
			self:ApplyScheme(flat)
		end
	end

	function ThemeManager:ThemeUpdate()
		local sch: { [string]: string } = {}
		for _, field in ThemeFields do
			local opt = self.Library.Options[field]
			if opt and typeof(opt.Value) == "Color3" then
				sch[field] = opt.Value:ToHex()
			end
		end
		self:ApplyScheme(sch)
	end

	function ThemeManager:GetCustomTheme(file: string): any
		local path = self.Folder .. "/themes/" .. file .. ".json"
		if not isfile(path) then
			return nil
		end
		local raw = readfile(path)
		local success, decoded = pcall(HttpService.JSONDecode, HttpService, raw)
		if not success then
			return nil
		end
		return decoded
	end

	function ThemeManager:LoadDefault()
		local theme = "Default"
		local content = isfile(self.Folder .. "/themes/default.txt") and readfile(self.Folder .. "/themes/default.txt")

		if content then
			content = content:gsub("%s+", "")
			if self.BuiltInThemes[content] then
				theme = content
			elseif self:GetCustomTheme(content) then
				theme = content
			end
		elseif self.BuiltInThemes[self.DefaultTheme] then
			theme = self.DefaultTheme
		end

		local listOpt = self.Library.Options.ThemeManager_ThemeList
		if listOpt and listOpt.SetValue then
			listOpt:SetValue(theme)
		end
		self:ApplyTheme(theme)
	end

	function ThemeManager:SaveDefault(theme: string)
		writefile(self.Folder .. "/themes/default.txt", theme)
	end

	function ThemeManager:SaveCustomTheme(file: string)
		if file:gsub(" ", "") == "" then
			self.Library:Notify({ Title = "Theme", Description = "Invalid theme name", Time = 3 })
			return
		end
		local theme: { [string]: string } = {}
		for _, field in ThemeFields do
			local opt = self.Library.Options[field]
			if opt and typeof(opt.Value) == "Color3" then
				theme[field] = opt.Value:ToHex()
			end
		end
		writefile(self.Folder .. "/themes/" .. file .. ".json", HttpService:JSONEncode(theme))
	end

	function ThemeManager:Delete(name: string)
		if not name then
			return false, "no theme selected"
		end
		local file = self.Folder .. "/themes/" .. name .. ".json"
		if not isfile(file) then
			return false, "invalid file"
		end
		if not pcall(delfile, file) then
			return false, "delete file error"
		end
		return true
	end

	function ThemeManager:ReloadCustomThemes(): { string }
		local list = listfiles(self.Folder .. "/themes")
		local out = {}
		if typeof(list) ~= "table" then
			return out
		end
		for i = 1, #list do
			local file = list[i]
			local base = jsonBasename(file)
			if base and base ~= "" then
				table.insert(out, base)
			end
		end
		return out
	end

