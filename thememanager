			self.Library.Options.ThemeManager_CustomThemeList:SetValues(self:ReloadCustomThemes())
			self.Library.Options.ThemeManager_CustomThemeList:SetValue(nil)
		end)

		section:AddDivider()

		section:AddDropdown({
			Text = "Custom themes",
			Options = self:ReloadCustomThemes(),
			AllowNull = true,
			Default = 1,
			Idx = "ThemeManager_CustomThemeList",
		})

		section:AddButton("Load custom theme", function()
			local name = self.Library.Options.ThemeManager_CustomThemeList.Value
			self:ApplyTheme(name)
			self.Library:Notify({ Title = "Theme", Description = string.format("Loaded %q", name), Time = 2 })
		end)

		section:AddButton("Overwrite custom theme", function()
			local name = self.Library.Options.ThemeManager_CustomThemeList.Value
			self:SaveCustomTheme(name)
			self.Library:Notify({ Title = "Theme", Description = string.format("Overwrote %q", name), Time = 2 })
		end)

		section:AddButton("Delete custom theme", function()
			local name = self.Library.Options.ThemeManager_CustomThemeList.Value
			local success, err = self:Delete(name)
			if not success then
				self.Library:Notify({ Title = "Theme", Description = tostring(err), Time = 3 })
				return
			end
			self.Library:Notify({ Title = "Theme", Description = string.format("Deleted %q", name), Time = 2 })
			self.Library.Options.ThemeManager_CustomThemeList:SetValues(self:ReloadCustomThemes())
			self.Library.Options.ThemeManager_CustomThemeList:SetValue(nil)
		end)

		section:AddButton("Refresh custom list", function()
			self.Library.Options.ThemeManager_CustomThemeList:SetValues(self:ReloadCustomThemes())
			self.Library.Options.ThemeManager_CustomThemeList:SetValue(nil)
		end)

		section:AddButton("Set custom as default", function()
			local name = self.Library.Options.ThemeManager_CustomThemeList.Value
			if name ~= nil and name ~= "" then
				self:SaveDefault(name)
				self.Library:Notify({
					Title = "Theme",
					Description = string.format("Default: %q", name),
					Time = 2,
				})
			end
		end)

		section:AddButton("Reset default.txt", function()
			if not pcall(delfile, self.Folder .. "/themes/default.txt") then
				self.Library:Notify({ Title = "Theme", Description = "Could not delete default.txt", Time = 3 })
				return
			end
			self.Library:Notify({ Title = "Theme", Description = "default.txt cleared", Time = 2 })
		end)

		for _, field in ThemeFields do
			local opt = self.Library.Options[field]
			if opt and opt.OnChanged then
				opt:OnChanged(function()
					self:ThemeUpdate()
				end)
			end
		end

		self:LoadDefault()
		self.AppliedToTab = true
	end

	function ThemeManager:CreateGroupBox(tab)
		assert(self.Library, "Must set ThemeManager.Library first!")
		if typeof(tab.AddRightGroupbox) == "function" then
			return tab:AddRightGroupbox("Themes")
		end
		return tab:AddSection("Themes")
	end

	function ThemeManager:ApplyToTab(tab)
		assert(self.Library, "Must set ThemeManager.Library first!")
		local section = self:CreateGroupBox(tab)
		self:CreateThemeManager(section)
	end

	function ThemeManager:ApplyToGroupbox(section)
		assert(self.Library, "Must set ThemeManager.Library first!")
		self:CreateThemeManager(section)
	end

