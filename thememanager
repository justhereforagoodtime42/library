local function jsonBasename(path: string): string?
	if path:sub(-5) ~= ".json" then
		return nil
	end
	local dot = path:find(".json", 1, true)
	if not dot then
		return nil
	end
	local slash = 0
	for i = dot - 1, 1, -1 do
		local c = path:sub(i, i)
		if c == "/" or c == "\\" then
			slash = i
			break
		end
	end
	return path:sub(slash + 1, dot - 1)
end

